---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  class:list={[
    `
      block h-4 w-full text-border
      forced-colors:invisible
    `,
    className,
  ]}
  aria-hidden="true"
>
  <defs>
    <pattern
      id="wave-divider-pattern"
      x="0"
      y="0"
      width="128"
      height="16"
      patternUnits="userSpaceOnUse"
    >
      <path
        d="M 0 8 Q 16 3 32 8 T 64 8 T 96 8 T 128 8"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </pattern>
  </defs>
  <rect width="100%" height="16" fill="url(#wave-divider-pattern)" />
</svg>
