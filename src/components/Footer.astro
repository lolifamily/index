---
import siteConfig from '@/config/site.config';

const { profile, footer: FooterSlot } = siteConfig;
---

<footer class="
  w-full py-2 text-center text-base text-primary
  [text-shadow:0_0_4px_var(--color-canvas),0_0_2px_var(--color-canvas)]
"
>
  <ul class="
    flex flex-wrap justify-center
    [&>li]:px-2
    [&>li:not(:first-child)]:border-l [&>li:not(:first-child)]:border-primary
  "
  >
    <li>
      &copy;
      {profile.name}
    </li>
    <li>
      Design:
      <a
        href="https://html5up.net"
        class="
          transition-colors
          hover:text-hover
          forced-colors:hover:text-[Highlight]
        "
      >
        <span class="underline">HTML5 UP</span>
      </a>
    </li>
    <FooterSlot />
  </ul>
</footer>
