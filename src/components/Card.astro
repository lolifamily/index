---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section
  class:list={[
    `
      relative isolate min-w-0 origin-center rounded-3xl border-2
      border-border-soft px-8 py-16 shadow-card
      before:absolute before:inset-0 before:-z-10 before:rounded-3xl
      before:bg-card before:opacity-40 before:content-['']
      dark:before:opacity-25
      reduce-transparency:before:opacity-100
      reduce-transparency:dark:before:opacity-100
      update-fast:motion-safe:animate-[identity-card-enter_1s_ease-out_forwards]
    `,
    className,
  ]}
>
  <slot />
</section>
