---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section
  class:list={[
    `
      relative isolate min-w-0 origin-center break-inside-avoid rounded-3xl
      border-2 border-border-soft px-8 shadow-card
      before:absolute before:inset-0 before:-z-10
      before:rounded-[calc(1.5rem-2px)] before:bg-card before:opacity-40
      before:inset-shadow-card before:content-['']
      dark:before:opacity-25
      reduce-transparency:before:opacity-100
      reduce-transparency:dark:before:opacity-100
      update-fast:motion-safe:animate-[identity-card-enter_0.75s_ease-out_forwards]
    `,
    className,
  ]}
>
  <slot />
</section>
