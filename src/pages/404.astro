---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/Card.astro';
import WaveDivider from '@/components/WaveDivider.astro';
import { getFullPath } from '@/utils/getpath';

import GhostIcon from '@phosphor-icons/core/assets/duotone/ghost-duotone.svg';
import HouseIcon from '@phosphor-icons/core/assets/duotone/house-duotone.svg';

const pageContext = {
  path: getFullPath('/404'),
  noindex: true,
};
---

<BaseLayout pageContext={pageContext}>
  <main class="flex w-full items-center justify-center">
    <Card class="
      w-full max-w-108 py-12 text-center
      md:min-w-108
    "
    >
      {/* 飘荡的小幽灵 */}
      <div class="mx-auto mb-8 w-fit text-card-heading">
        <GhostIcon width="6rem" height="6rem" aria-hidden="true" />
      </div>

      {/* 错误码 */}
      <h1 class="
        mb-4 font-identity text-6xl font-light tracking-widest text-card-heading
      "
      >
        404
      </h1>

      {/* 副标题 */}
      <p class="
        mb-4 font-identity text-base/loose tracking-widest text-primary
        uppercase
      "
      >
        Page Not Found
      </p>

      {/* 手绘风格波浪分隔 */}
      <WaveDivider class="mb-4" />

      {/* 描述 */}
      <p class="mb-10 text-base text-muted">
        迷路啦～这里什么都没有～
      </p>

      {/* 返回按钮 */}
      <a
        href={getFullPath('/')}
        class="
          inline-flex items-center gap-2 rounded-full border-2 border-border
          px-6 py-3 text-base tracking-widest text-primary uppercase
          transition-[scale,border-color,color] duration-200
          hover:scale-105 hover:border-hover hover:text-hover
        "
      >
        <HouseIcon width="1.25rem" height="1.25rem" aria-hidden="true" />
        回到首页
      </a>
    </Card>
  </main>
</BaseLayout>
