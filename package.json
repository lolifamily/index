{
  "name": "profile",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "dev:full": "astro dev --force",
    "build": "astro build",
    "build:full": "astro build --force",
    "preview": "astro preview",
    "sync": "astro sync",
    "typecheck": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:interactive": "eslint-interactive .",
    "online": "pnpm run online:workers && pnpm run online:pages && pnpm run online:vercel && pnpm run online:netlify",
    "online:workers": "pnpx wrangler@latest -c wrangler-workers.jsonc deploy",
    "online:pages": "pnpx wrangler@latest pages deploy",
    "online:vercel": "pnpx vercel@latest --cwd dist deploy --prod",
    "online:netlify": "pnpx --config.trust-policy= --package netlify-cli@latest netlify deploy --no-build --prod"
  },
  "dependencies": {
    "@astrojs/compiler-rs": "^0.2.3",
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/solid-js": "^7.0.0",
    "@astrojs/ts-plugin": "^1.10.9",
    "@fontsource-variable/comfortaa": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/core": "^2.1.1",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "hastscript": "^9.0.1",
    "lightningcss": "^1.32.0",
    "medium-zoom-next": "^2.0.1",
    "pangu": "^7.2.1",
    "rehype": "^13.0.2",
    "satteri": "^0.9.3",
    "sharp": "^0.35.2",
    "solid-js": "^1.9.13",
    "tailwindcss": "^4.3.1",
    "terser": "^5.48.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/language-server": "^2.16.10",
    "@eslint/css": "1.3.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/language-server": "^0.14.29",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.1",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-interactive": "^14.0.0",
    "eslint-mdx": "^3.8.1",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.8.1",
    "eslint-plugin-solid": "^0.14.5",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-csstree": "^0.3.3",
    "typescript-eslint": "^8.62.0"
  },
  "packageManager": "pnpm@11.9.0"
}
