{
  "name": "profile",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "dev:full": "astro dev --force",
    "build": "astro build",
    "build:full": "astro build --force",
    "preview": "astro preview",
    "sync": "astro sync",
    "typecheck": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:interactive": "eslint-interactive .",
    "online": "pnpm run online:workers && pnpm run online:pages && pnpm run online:vercel && pnpm run online:netlify",
    "online:workers": "pnpx wrangler@latest -c wrangler-workers.jsonc deploy",
    "online:pages": "pnpx wrangler@latest pages deploy",
    "online:vercel": "pnpx vercel@latest --cwd dist deploy --prod",
    "online:netlify": "pnpx --config.trust-policy= --package netlify-cli@latest netlify deploy --no-build --prod"
  },
  "dependencies": {
    "@astrojs/compiler-rs": "^0.1.10",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/solid-js": "^6.0.1",
    "@astrojs/ts-plugin": "^1.10.7",
    "@fontsource-variable/comfortaa": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/core": "^2.1.1",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "hastscript": "^9.0.1",
    "lightningcss": "^1.32.0",
    "medium-zoom-next": "^2.0.1",
    "pangu": "^7.2.1",
    "rehype": "^13.0.2",
    "remark": "^15.0.1",
    "remark-definition-list": "^2.0.0",
    "remark-directive": "^4.0.0",
    "remark-emoji": "^5.0.2",
    "remark-github-admonitions-to-directives": "^2.1.0",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.12",
    "tailwindcss": "^4.2.4",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "unist-util-visit-parents": "^6.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/language-server": "^2.16.7",
    "@eslint/css": "1.2.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/language-server": "^0.14.29",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "eslint-interactive": "^13.0.1",
    "eslint-mdx": "^3.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-solid": "^0.14.5",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-csstree": "^0.3.1",
    "typescript-eslint": "^8.59.1"
  },
  "remarkConfig": {
    "plugins": [
      "remark-frontmatter",
      "remark-github-admonitions-to-directives",
      "remark-directive",
      "remark-emoji",
      "remark-gfm"
    ]
  },
  "packageManager": "pnpm@10.33.2"
}
